---
import ButtonMainColor from "./ButtonMainColor.astro";
---

<section class="dual-container">
  <div class="video-card">
    <video
      autoplay
      muted
      loop
      playsinline
      poster="/assets/poster-info.jpg"
      class="card-video"
    >
      <source
        src="/assets/info-background.webm"
        type="video/webm"
      />
    </video>
    <div class="card-overlay">
      <h2>
        "Se diseña con pluma, pero se recuerda con el corazón"
      </h2>
    </div>
  </div>

  <div class="info-card">
    <div class="phrases-container">
      <div class="phrase-item">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="icon-mail"
          ><path d="m22 7-8.991 5.727a2 2 0 0 1-2.009 0L2 7"></path><rect
            x="2"
            y="4"
            width="20"
            height="16"
            rx="2"></rect></svg
        >
        <p>Una carta hecha a mano no se borra, se atesora.</p>
      </div>
      <div class="phrase-item">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="icon-mail"
          ><path d="m22 7-8.991 5.727a2 2 0 0 1-2.009 0L2 7"></path><rect
            x="2"
            y="4"
            width="20"
            height="16"
            rx="2"></rect></svg
        >
        <p>Transforma palabras en recuerdos imborrables.</p>
      </div>
      <div class="phrase-item">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="icon-mail"
          ><path d="m22 7-8.991 5.727a2 2 0 0 1-2.009 0L2 7"></path><rect
            x="2"
            y="4"
            width="20"
            height="16"
            rx="2"></rect></svg
        >
        <p>La última carta que tu persona amada guardará para siempre.</p>
      </div>
    </div>

    <ButtonMainColor url="/reason" class={"hero-button"}>
      Regala un recuerdo
    </ButtonMainColor>
  </div>
</section>

<style>
  .dual-container {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    padding: 4rem 2rem;
    max-width: 1400px;
    margin: 0 auto;
    min-height: 80vh;
  }

  /* --- Bloque Video (60-65% de ancho) --- */
  .video-card {
    position: relative;
    flex: 0 0 60%; /* Ocupa el 60% fijo */
    height: stretch;
    max-height: 500px;
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 5px 10px rgba(0, 0, 0, 0.2);
  }

  .card-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.7) 0%, transparent 80%);
    display: flex;
    align-items: flex-end;
    justify-content: end;
    padding: 2rem;
  }

  .card-overlay h2 {
    color: white;
    font-size: var(--font-semi-big);
    font-weight: 600;
    max-width: 25rem;
    margin: 0;
    line-height: 1.2;
    text-align: end;
  }

  /* --- Bloque Info (30-35% de ancho) --- */
  .info-card {
    flex: 0 0 35%; /* Ocupa menos espacio */
    display: flex;
    flex-direction: column;
    justify-content: center; /* Centra el contenido verticalmente */
    align-items: center;
    gap: 3rem;
    padding-left: 1rem;
  }

  .phrases-container {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .phrase-item {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .icon-mail {
    color: #3c99ba;
    flex-shrink: 0;
  }

  .phrase-item p {
    color: black;
    font-size: 1.1rem;
    margin: 0;
    line-height: 1.4;
  }

  /* Estilo del botón (ajustado a tu diseño) */
  .hero-button {
    width: fit-content;
    backdrop-filter: blur(8px);
    border: 1px solid #3c99ba;
    padding: 1rem 2rem;
    color: white;
    transition: all 0.2s ease;
    box-shadow: 0px 0px 10px rgba(60, 153, 186, 0.3);
  }

  .hero-button:hover {
    background-color: var(--main-light-accent-color);
    color: black;
  }

  /* --- Responsive --- */
  @media (max-width: 1024px) {
    .dual-container {
      flex-direction: column;
      align-items: center;
    }

    .video-card,
    .info-card {
      flex: 0 0 100%;
      width: 100%;
    }

    .video-card {
      max-height: 400px;
    }

    .info-card {
      padding: 2rem 0;
      align-items: center;
    }

    .phrase-item {
      justify-content: start;
      text-align: start;
    }
  }
</style>
