---
import ButtonMainColor from "./ButtonMainColor.astro";
---

<section class="hero">
  <video
    autoplay
    muted
    loop
    playsinline
    poster="/assets/hero-fallback.webp"
    class="hero-bg"
  >
    <source src="/assets/hero-background.webm" type="video/webm"/>
  </video>
  <div class="hero-content">
    <h1>"Una carta hecha a mano — valor que ninguna pantalla puede igualar"</h1>
    <ButtonMainColor url="/reason" class={"hero-button"}
      >Empieza a escribrir recuerdos</ButtonMainColor
    >
  </div>
</section>

<style>
  .hero {
    position: relative;
    height: calc(100dvh - 4rem);
    overflow: hidden;
    margin-top: 4rem;
  }

  .hero-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: -1;
  }

  .hero-content {
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.2);
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: end;
    padding: 5rem 4rem;
  }

  h1 {
    font-size: 1.8rem;
    max-width: 25rem;
    color: white;
    text-align: end;
  }

  .btn-base.hero-button {
    background-color: rgba(0, 0, 0, 0.3);
    backdrop-filter: blur(10px);
    border-style: solid;
    border-color: #3c99ba;
    box-shadow: 0px 0px 10px var(--main-accent-color);
  }
  .btn-base.hero-button:hover {
    background-color: rgb(from var(--main-accent-color) r g b / 0.5);
  }

  @media (max-width: 768px) {
    .hero {
      height: 75dvh;
    }
    .hero-bg {
      object-position: 40% center;
    }
    .hero-content {
      justify-content: end;
      align-items: center;
      gap: 2rem;
      padding: 2rem;
    }
    h1 {
      font-size: 1.4rem;
      text-align: center;
    }
  }
</style>
